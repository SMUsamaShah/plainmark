{
   "manifest_version": 2,
   "name": "HTML Selection",
   "description": "Gets the HTML of the user's selection",
   "version": "0.3",
   
   "browser_action": {
      "default_icon": "icon_32.png",
      "default_title": "Get selected HTML"
   },
   "icons": {
      "32": "icon_32.png"
   },
   "permissions": [
      "http://*/*",
      "https://*/*",
      "tabs",
      "contextMenus",
      "storage"
   ],
   "background": {
      "scripts": [
         "util.js", 
         "dynalist.js",
         "background.js"
      ]
   },
   "content_scripts": [ 
      {
         "matches": [
            "http://*/*", 
            "https://*/*",
            "*://*/*"
         ],
         "js": ["content_script.js"]
       }
   ],
   "web_accessible_resources": [
      "popup.html"
   ]
}